<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.codex.sik.wapi</string>

  <key>ProgramArguments</key>
  <array>
    <string>/Applications/MAMP/htdocs/sik/scripts/start-wapi.sh</string>
  </array>

  <key>RunAtLoad</key>
  <true/>

  <key>KeepAlive</key>
  <true/>

